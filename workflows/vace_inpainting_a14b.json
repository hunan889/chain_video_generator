{
  "_meta": {
    "title": "VACE Inpainting A14B - Video Person Replacement",
    "description": "Replace masked regions in a video with new content guided by text prompt and optional reference image. Use for person replacement: mask the person area, provide a description of the replacement.",
    "inputs": {
      "positive_prompt": "node 9, positive_prompt - describe the replacement person/scene",
      "input_video": "node 11, video - source video file (uploaded to ComfyUI input/)",
      "input_masks": "node 20, video - mask video where white=replace, black=keep (uploaded to ComfyUI input/)",
      "ref_image": "node 12, image - optional reference image for replacement subject",
      "seed": "node 14 & 15, seed",
      "strength": "node 13, strength - how much VACE controls generation (0.0-10.0, default 1.0)",
      "width": "node 13, width (default 832)",
      "height": "node 13, height (default 480)",
      "num_frames": "node 13, num_frames (default 81, must be 4n+1)"
    }
  },
  "1": {
    "class_type": "WanVideoVACEModelSelect",
    "inputs": {
      "vace_model": "Wan2_2_Fun_VACE_module_A14B_HIGH_fp8_e4m3fn_scaled_KJ.safetensors"
    }
  },
  "2": {
    "class_type": "WanVideoVACEModelSelect",
    "inputs": {
      "vace_model": "Wan2_2_Fun_VACE_module_A14B_LOW_fp8_e4m3fn_scaled_KJ.safetensors"
    }
  },
  "3": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "Wan2_2-T2V-A14B_HIGH_fp8_e4m3fn_scaled_KJ.safetensors",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn_scaled",
      "load_device": "offload_device",
      "attention_mode": "sageattn",
      "extra_model": ["1", 0]
    }
  },
  "4": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "Wan2_2-T2V-A14B-LOW_fp8_e4m3fn_scaled_KJ.safetensors",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn_scaled",
      "load_device": "offload_device",
      "attention_mode": "sageattn",
      "extra_model": ["2", 0]
    }
  },
  "5": {
    "class_type": "WanVideoBlockSwap",
    "inputs": {
      "blocks_to_swap": 20,
      "offload_img_emb": true,
      "offload_txt_emb": true,
      "vace_blocks_to_swap": 10
    }
  },
  "6": {
    "class_type": "WanVideoSetBlockSwap",
    "inputs": {
      "model": ["3", 0],
      "block_swap_args": ["5", 0]
    }
  },
  "7": {
    "class_type": "WanVideoSetBlockSwap",
    "inputs": {
      "model": ["4", 0],
      "block_swap_args": ["5", 0]
    }
  },
  "8": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "umt5-xxl-enc-fp8_e4m3fn.safetensors",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "disabled"
    }
  },
  "9": {
    "class_type": "WanVideoTextEncode",
    "inputs": {
      "positive_prompt": "",
      "negative_prompt": "色调艳丽，过曝，静态，细节模糊不清，字幕，风格，作品，画作，画面，静止，整体发灰，最差质量，低质量，JPEG压缩残留，丑陋的，残缺的，多余的手指，画得不好的手部，画得不好的脸部，畸形的，毁容的，形态畸形的肢体，手指融合，静止不动的画面，杂乱的背景，三条腿，背景人很多，倒着走",
      "t5": ["8", 0],
      "force_offload": true
    }
  },
  "10": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "Wan2_1_VAE_bf16.safetensors",
      "precision": "bf16"
    }
  },
  "11": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "input_video.mp4",
      "force_rate": 0,
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 81,
      "skip_first_frames": 0,
      "select_every_nth": 1
    }
  },
  "12": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "reference_person.png"
    }
  },
  "13": {
    "class_type": "WanVideoVACEEncode",
    "inputs": {
      "vae": ["10", 0],
      "width": 832,
      "height": 480,
      "num_frames": 81,
      "strength": 1.0,
      "vace_start_percent": 0.0,
      "vace_end_percent": 1.0,
      "input_frames": ["11", 0],
      "ref_images": ["12", 0],
      "input_masks": ["21", 0]
    }
  },
  "14": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["6", 0],
      "image_embeds": ["13", 0],
      "text_embeds": ["9", 0],
      "steps": 30,
      "cfg": 6.0,
      "shift": 5.0,
      "seed": 0,
      "force_offload": true,
      "scheduler": "dpm++_sde",
      "riflex_freq_index": 0,
      "start_step": 0,
      "end_step": 15
    }
  },
  "15": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["7", 0],
      "image_embeds": ["13", 0],
      "text_embeds": ["9", 0],
      "samples": ["14", 0],
      "steps": 30,
      "cfg": 6.0,
      "shift": 5.0,
      "seed": 0,
      "force_offload": true,
      "scheduler": "dpm++_sde",
      "riflex_freq_index": 0,
      "start_step": 15,
      "end_step": -1,
      "denoise_strength": 1.0
    }
  },
  "16": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["10", 0],
      "samples": ["15", 0],
      "enable_vae_tiling": false,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "17": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["16", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "wan22_vace_inpaint",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  },
  "20": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "input_mask.mp4",
      "force_rate": 0,
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 81,
      "skip_first_frames": 0,
      "select_every_nth": 1
    }
  },
  "21": {
    "class_type": "ImageToMask",
    "inputs": {
      "image": ["20", 0],
      "channel": "red"
    }
  }
}
