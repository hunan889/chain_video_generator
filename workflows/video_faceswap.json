{
  "1": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "input_video.mp4",
      "force_rate": 0,
      "force_size": "Disabled",
      "custom_width": 512,
      "custom_height": 512,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1
    }
  },
  "2": {
    "class_type": "Load Face Swap Model (mtb)",
    "inputs": {
      "faceswap_model": "inswapper_128.onnx"
    }
  },
  "3": {
    "class_type": "Load Face Analysis Model (mtb)",
    "inputs": {
      "faceanalysis_model": "buffalo_l"
    }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "face_reference.png"
    }
  },
  "5": {
    "class_type": "Face Swap (mtb)",
    "inputs": {
      "image": ["1", 0],
      "reference": ["4", 0],
      "swapper_model": ["2", 0],
      "faceanalysis_model": ["3", 0],
      "faces_index": "0"
    }
  },
  "6": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "faceswap",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true,
      "images": ["5", 0]
    }
  }
}
