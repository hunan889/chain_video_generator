{
  "_meta": {
    "title": "VACE FLF2V A14B - First/Last Frame to Video",
    "description": "Generate a video by specifying the first frame and optionally the last frame. The model interpolates smooth motion between them guided by text prompt. Great for controlled transitions and consistent character animation.",
    "inputs": {
      "positive_prompt": "node 9, positive_prompt - describe the scene and motion",
      "start_image": "node 18, image - first frame image (required)",
      "end_image": "node 19, image - last frame image (optional, omit node 19 to use start-only mode)",
      "seed": "node 14 & 15, seed",
      "strength": "node 13, strength - VACE control strength (default 1.0)",
      "width": "node 13, width (default 832)",
      "height": "node 13, height (default 480)",
      "num_frames": "node 13, num_frames (default 81, must be 4n+1)"
    }
  },
  "1": {
    "class_type": "WanVideoVACEModelSelect",
    "inputs": {
      "vace_model": "Wan2_2_Fun_VACE_module_A14B_HIGH_fp8_e4m3fn_scaled_KJ.safetensors"
    }
  },
  "2": {
    "class_type": "WanVideoVACEModelSelect",
    "inputs": {
      "vace_model": "Wan2_2_Fun_VACE_module_A14B_LOW_fp8_e4m3fn_scaled_KJ.safetensors"
    }
  },
  "3": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "Wan2_2-T2V-A14B_HIGH_fp8_e4m3fn_scaled_KJ.safetensors",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn_scaled",
      "load_device": "offload_device",
      "attention_mode": "sageattn",
      "extra_model": ["1", 0]
    }
  },
  "4": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "Wan2_2-T2V-A14B-LOW_fp8_e4m3fn_scaled_KJ.safetensors",
      "base_precision": "bf16",
      "quantization": "fp8_e4m3fn_scaled",
      "load_device": "offload_device",
      "attention_mode": "sageattn",
      "extra_model": ["2", 0]
    }
  },
  "5": {
    "class_type": "WanVideoBlockSwap",
    "inputs": {
      "blocks_to_swap": 20,
      "offload_img_emb": true,
      "offload_txt_emb": true,
      "vace_blocks_to_swap": 10
    }
  },
  "6": {
    "class_type": "WanVideoSetBlockSwap",
    "inputs": {
      "model": ["3", 0],
      "block_swap_args": ["5", 0]
    }
  },
  "7": {
    "class_type": "WanVideoSetBlockSwap",
    "inputs": {
      "model": ["4", 0],
      "block_swap_args": ["5", 0]
    }
  },
  "8": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "umt5-xxl-enc-fp8_e4m3fn.safetensors",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "disabled"
    }
  },
  "9": {
    "class_type": "WanVideoTextEncode",
    "inputs": {
      "positive_prompt": "",
      "negative_prompt": "色调艳丽，过曝，静态，细节模糊不清，字幕，风格，作品，画作，画面，静止，整体发灰，最差质量，低质量，JPEG压缩残留，丑陋的，残缺的，多余的手指，画得不好的手部，画得不好的脸部，畸形的，毁容的，形态畸形的肢体，手指融合，静止不动的画面，杂乱的背景，三条腿，背景人很多，倒着走",
      "t5": ["8", 0],
      "force_offload": true
    }
  },
  "10": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "Wan2_1_VAE_bf16.safetensors",
      "precision": "bf16"
    }
  },
  "13": {
    "class_type": "WanVideoVACEEncode",
    "inputs": {
      "vae": ["10", 0],
      "width": 832,
      "height": 480,
      "num_frames": 81,
      "strength": 1.0,
      "vace_start_percent": 0.0,
      "vace_end_percent": 1.0,
      "input_frames": ["20", 0],
      "input_masks": ["20", 1]
    }
  },
  "14": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["6", 0],
      "image_embeds": ["13", 0],
      "text_embeds": ["9", 0],
      "steps": 30,
      "cfg": 6.0,
      "shift": 5.0,
      "seed": 0,
      "force_offload": true,
      "scheduler": "dpm++_sde",
      "riflex_freq_index": 0,
      "start_step": 0,
      "end_step": 15
    }
  },
  "15": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["7", 0],
      "image_embeds": ["13", 0],
      "text_embeds": ["9", 0],
      "samples": ["14", 0],
      "steps": 30,
      "cfg": 6.0,
      "shift": 5.0,
      "seed": 0,
      "force_offload": true,
      "scheduler": "dpm++_sde",
      "riflex_freq_index": 0,
      "start_step": 15,
      "end_step": -1,
      "denoise_strength": 1.0
    }
  },
  "16": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["10", 0],
      "samples": ["15", 0],
      "enable_vae_tiling": false,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "17": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["16", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "wan22_vace_flf2v",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  },
  "18": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "start_frame.png"
    }
  },
  "19": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "end_frame.png"
    }
  },
  "20": {
    "class_type": "WanVideoVACEStartToEndFrame",
    "inputs": {
      "num_frames": 81,
      "empty_frame_level": 0.5,
      "start_image": ["18", 0],
      "end_image": ["19", 0]
    }
  }
}
