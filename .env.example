# Wan2.2 Video Generation Service Configuration
# Copy to .env and adjust as needed: cp .env.example .env

# ComfyUI
COMFYUI_PATH=./ComfyUI
COMFYUI_A14B_URL=http://127.0.0.1:8188
COMFYUI_5B_URL=http://127.0.0.1:8189

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000

# Storage & Config (relative to project root)
STORAGE_PATH=./storage
API_KEYS_PATH=./config/api_keys.yaml
LORAS_PATH=./config/loras.yaml
VIDEO_BASE_URL=/api/v1/results

# GPU allocation
A14B_GPU_IDS=0,1
FIVE_B_GPU_ID=2

# ComfyUI ports
COMFYUI_A14B_PORT=8188
COMFYUI_5B_PORT=8189

# CivitAI (optional, for LoRA downloads)
# CIVITAI_API_TOKEN=your_token_here

# Anthropic (for AI prompt optimization)
# ANTHROPIC_API_KEY=your_key_here
