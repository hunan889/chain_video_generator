# Wan2.2 Video Generation Service Configuration
# Copy to .env and adjust as needed: cp .env.example .env

# ComfyUI
COMFYUI_PATH=./ComfyUI
# Multi-instance A14B: comma-separated URLs (or single URL for backward compat)
COMFYUI_A14B_URLS=http://127.0.0.1:8188,http://127.0.0.1:8191,http://127.0.0.1:8192,http://127.0.0.1:8193
# Legacy single-URL (used if COMFYUI_A14B_URLS is not set):
# COMFYUI_A14B_URL=http://127.0.0.1:8188
COMFYUI_5B_URL=http://127.0.0.1:8189

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000

# Storage & Config (relative to project root)
STORAGE_PATH=./storage
API_KEYS_PATH=./config/api_keys.yaml
LORAS_PATH=./config/loras.yaml
VIDEO_BASE_URL=/api/v1/results

# GPU allocation (per A14B instance)
A14B_GPU_IDS=2       # Instance 0
A14B_GPU_IDS_1=3     # Instance 1
A14B_GPU_IDS_2=4     # Instance 2
A14B_GPU_IDS_3=7     # Instance 3
FIVE_B_GPU_ID=5

# ComfyUI ports (per A14B instance)
COMFYUI_A14B_PORT=8188     # Instance 0
COMFYUI_A14B_PORT_1=8191   # Instance 1
COMFYUI_A14B_PORT_2=8192   # Instance 2
COMFYUI_A14B_PORT_3=8193   # Instance 3
COMFYUI_5B_PORT=8189

# Number of A14B instances to start (used by start_all.sh)
A14B_INSTANCE_COUNT=4

# CivitAI (optional, for LoRA downloads)
# CIVITAI_API_TOKEN=your_token_here

# Anthropic (for AI prompt optimization)
# ANTHROPIC_API_KEY=your_key_here

# Tencent COS (optional, leave COS_BUCKET empty to use local storage)
# COS_SECRET_ID=your_secret_id
# COS_SECRET_KEY=your_secret_key
# COS_BUCKET=your-bucket-name
# COS_REGION=ap-guangzhou
# COS_PREFIX=wan22
