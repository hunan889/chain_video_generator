# GPU Worker — copy to gpu_worker/.env and fill in real values
# cp gpu_worker/.env.example gpu_worker/.env

# -----------------------------------------------------------------
# Worker identity
# -----------------------------------------------------------------
WORKER_ID=gpu-worker-1

# -----------------------------------------------------------------
# Redis (same instance as API Gateway)
# -----------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0

# -----------------------------------------------------------------
# Task
# -----------------------------------------------------------------
TASK_EXPIRY=86400

# -----------------------------------------------------------------
# Heartbeat
# -----------------------------------------------------------------
HEARTBEAT_INTERVAL=30

# -----------------------------------------------------------------
# ComfyUI instance URLs
# Format: comma-separated list of model_key=url pairs
# model_key must match the queue key used by the API Gateway
# (e.g. "a14b" → Redis queue "queue:a14b")
# -----------------------------------------------------------------
# JSON dict mapping model_key to ComfyUI URL
# model_key must match the queue key used by the API Gateway
# (e.g. "a14b" -> Redis queue "queue:a14b")
COMFYUI_URLS={"a14b": "http://127.0.0.1:8188", "5b": "http://127.0.0.1:8189"}

# -----------------------------------------------------------------
# Tencent Cloud Object Storage (COS)
# Must match the API Gateway COS config.
# -----------------------------------------------------------------
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_PREFIX=wan22
COS_CDN_DOMAIN=
