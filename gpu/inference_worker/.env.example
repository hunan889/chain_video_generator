# Inference Worker — copy to gpu/inference_worker/.env and fill in real values

# Identity
INFERENCE_WORKER_ID=inference-worker-1

# Redis (same instance as the rest of the system)
REDIS_URL=redis://:Docare123456@127.0.0.1:6399/8

# Embedding model (sentence-transformers, loaded in-process)
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# Use a specific GPU index. On 148 the default plan puts BGE on GPU 7
# (shared with Reactor — BGE only needs ~3 GB).
# Note: when CUDA_VISIBLE_DEVICES is set externally to a single GPU
# (e.g. =7), set this to "cuda" so torch sees the masked-in card as cuda:0.
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32

# vLLM endpoints (loopback only)
LLM_BASE_URL=http://127.0.0.1:20001/v1
LLM_MODEL=Qwen3-14B-v2-Abliterated
VLM_BASE_URL=http://127.0.0.1:20010/v1
VLM_MODEL=Qwen2.5-VL-7B-Instruct-Unredacted-MAX

# Worker behaviour
INFERENCE_BLPOP_TIMEOUT=1
INFERENCE_TASK_EXPIRY=300
HEARTBEAT_INTERVAL=30
