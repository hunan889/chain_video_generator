# API Gateway — copy to api_gateway/.env and fill in real values
# cp api_gateway/.env.example api_gateway/.env

# -----------------------------------------------------------------
# Redis (shared with existing service — same Redis, same DB is fine)
# -----------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0

# -----------------------------------------------------------------
# HTTP server
# NOTE: Use port 9000 to avoid conflicting with the existing service
# on port 8000 during parallel-run / cutover period.
# -----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=9000

# -----------------------------------------------------------------
# Task
# -----------------------------------------------------------------
TASK_EXPIRY=86400

# -----------------------------------------------------------------
# WorkflowBuilder — path to workflows/ directory containing JSON templates
# Absolute path is safest for systemd units.
# -----------------------------------------------------------------
WORKFLOWS_DIR=/home/gime/soft/wan22-service/workflows

# -----------------------------------------------------------------
# Tencent Cloud Object Storage (COS)
# -----------------------------------------------------------------
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_PREFIX=wan22
COS_CDN_DOMAIN=

# -----------------------------------------------------------------
# Vision model (for auto-continue last-frame description)
# Compatible with any OpenAI-compatible API (e.g. GPT-4o, Claude, etc.)
# Leave blank to disable auto-continue VLM feature.
# -----------------------------------------------------------------
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=gpt-4o

# -----------------------------------------------------------------
# LLM (for auto-continue prompt generation)
# Leave blank to disable auto-continue LLM feature.
# -----------------------------------------------------------------
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o
